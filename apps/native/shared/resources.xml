<!--
  Mochi DAW · native app resources

  Paths are relative to THIS file.  The build's resource generator
  (frameworks/SphereEngine/scripts/gen_resources.ts) reads every <file>
  entry, embeds its raw bytes into the MochiDAW exe, and registers them
  with ResourceManager under "res://<relative path>".

  How to consume at runtime:
    • Any SVG icon                IconNode::setIcon("res://icons/foo.svg")
                                  or just IconNode::setIcon("foo")  (auto-prefixed)
    • Any binary blob (TTF, PNG)  ResourceManager::getInstance()
                                     .getResource("res://fonts/Inter-Regular.ttf")

  Loaded together with the framework's own res:// set (chrome icons,
  scrollbars, etc.) which lives in SphereEngine's example/shared/resources.

  NOTE on fonts:  the framework's FontManager currently uses
  SkFontMgr_New_DirectWrite() — system-installed fonts only.  TTF bytes
  registered here are accessible via ResourceManager but not yet auto-wired
  into FontManager text rendering.  Until a FontManager::registerFontData
  hook exists, treat these as "embedded for the future bootstrap that builds
  an SkTypeface::MakeFromData(...)" — they will not affect rendering today
  unless Inter is also installed on the system.
-->
<resources>

    <!-- Inter UI font family — primary type used by the web shell.
         Mirrors the .ttf files shipped under shared/fonts/. -->
    <file>fonts/Inter-Thin.ttf</file>
    <file>fonts/Inter-ThinItalic.ttf</file>
    <file>fonts/Inter-ExtraLight.ttf</file>
    <file>fonts/Inter-ExtraLightItalic.ttf</file>
    <file>fonts/Inter-Light.ttf</file>
    <file>fonts/Inter-LightItalic.ttf</file>
    <file>fonts/Inter-Regular.ttf</file>
    <file>fonts/Inter-Italic.ttf</file>
    <file>fonts/Inter-Medium.ttf</file>
    <file>fonts/Inter-MediumItalic.ttf</file>
    <file>fonts/Inter-SemiBold.ttf</file>
    <file>fonts/Inter-SemiBoldItalic.ttf</file>
    <file>fonts/Inter-Bold.ttf</file>
    <file>fonts/Inter-BoldItalic.ttf</file>
    <file>fonts/Inter-ExtraBold.ttf</file>
    <file>fonts/Inter-ExtraBoldItalic.ttf</file>
    <file>fonts/Inter-Black.ttf</file>
    <file>fonts/Inter-BlackItalic.ttf</file>

    <!-- Inter Display — tighter optical sizing, used for large headings. -->
